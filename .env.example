# =============================================================================
# KOCH AI — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in values before running docker compose.
# All secrets stay on-premise. No external API calls are made.
# =============================================================================

# ---------------------------------------------------------------------------
# AI API — External Inference Engine
# ---------------------------------------------------------------------------
# Base URL for the AI API
VLLM_BASE_URL=https://api.ingham.ai/v1

# API Key for authentication
VLLM_API_KEY=inghamai-8101997

# Model to serve
LLM_MODEL=google/gemma-4-26b-it

# ---------------------------------------------------------------------------
# Hindsight — Temporal Memory Graph
# ---------------------------------------------------------------------------
HINDSIGHT_API_KEY=koch-hindsight-key
HINDSIGHT_PORT=8100

# ---------------------------------------------------------------------------
# Backend API
# ---------------------------------------------------------------------------
BACKEND_PORT=8000

# CORS origins (comma-separated) — restrict to frontend in production
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Node environment
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# =============================================================================
# Mobile Field Assistant (Telegram Bot)
# =============================================================================
# Obtain a token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated list of securely verified Telegram User IDs
ALLOWED_USER_IDS=123456789,987654321

# Maximum upload file size in MB
MAX_UPLOAD_SIZE_MB=100

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Workers
# ---------------------------------------------------------------------------
WORKER_PORT=9000
